{
  "info": {
    "_postman_id": "netflix-clone-api-collection",
    "name": "Netflix Clone API",
    "description": "Complete API collection for the Netflix Clone backend. Set the `baseUrl` environment variable to `http://localhost:5000/api`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.data && r.data.token) pm.collectionVariables.set('token', r.data.token);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@netflix.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/profile", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/users/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Updated\",\n  \"profilePic\": \"\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/users/change-password",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword456\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Get All Movies",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies?page=1&limit=12" }
        },
        {
          "name": "Get Trending Movies",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/trending?limit=10" }
        },
        {
          "name": "Get Recommended Movies",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/recommended?limit=10" }
        },
        {
          "name": "Search Movies",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/search?keyword=avengers" }
        },
        {
          "name": "Filter by Genre",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/genre/Action?limit=12" }
        },
        {
          "name": "Get Single Movie",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/MOVIE_ID_HERE" }
        },
        {
          "name": "Create Movie (Admin)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/movies",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Inception\",\n  \"description\": \"A thief who steals corporate secrets through dream-sharing technology.\",\n  \"genre\": [\"Sci-Fi\", \"Thriller\", \"Action\"],\n  \"year\": 2010,\n  \"rating\": 8.8,\n  \"duration\": \"2h 28m\",\n  \"thumbnail\": \"https://image.tmdb.org/t/p/w500/9gk7adHYeDvHkCSEqAvQNLV5Uge.jpg\",\n  \"isTrending\": true,\n  \"isRecommended\": true\n}" }
          }
        },
        {
          "name": "Update Movie (Admin)",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/movies/MOVIE_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 9.0,\n  \"isTrending\": true\n}" }
          }
        },
        {
          "name": "Delete Movie (Admin)",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/movies/MOVIE_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "TV Shows",
      "item": [
        {
          "name": "Get All TV Shows",
          "request": { "method": "GET", "url": "{{baseUrl}}/tvshows?page=1&limit=12" }
        },
        {
          "name": "Get Trending TV Shows",
          "request": { "method": "GET", "url": "{{baseUrl}}/tvshows/trending?limit=10" }
        },
        {
          "name": "Search TV Shows",
          "request": { "method": "GET", "url": "{{baseUrl}}/tvshows/search?keyword=stranger" }
        },
        {
          "name": "Filter TV Shows by Genre",
          "request": { "method": "GET", "url": "{{baseUrl}}/tvshows/genre/Drama?limit=12" }
        },
        {
          "name": "Create TV Show (Admin)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/tvshows",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Breaking Bad\",\n  \"description\": \"A high school chemistry teacher turned meth cook.\",\n  \"genre\": [\"Drama\", \"Crime\", \"Thriller\"],\n  \"year\": 2008,\n  \"rating\": 9.5,\n  \"seasons\": 5,\n  \"episodes\": 62,\n  \"thumbnail\": \"https://image.tmdb.org/t/p/w500/ggFHVNu6YYI5L9pCfOacjizRGt.jpg\",\n  \"isTrending\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "Watchlist",
      "item": [
        {
          "name": "Get Watchlist",
          "request": { "method": "GET", "url": "{{baseUrl}}/watchlist", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Add Movie to Watchlist",
          "request": { "method": "POST", "url": "{{baseUrl}}/watchlist/movie/MOVIE_ID_HERE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Remove Movie from Watchlist",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/watchlist/movie/MOVIE_ID_HERE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Add TV Show to Watchlist",
          "request": { "method": "POST", "url": "{{baseUrl}}/watchlist/tvshow/TVSHOW_ID_HERE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Remove TV Show from Watchlist",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/watchlist/tvshow/TVSHOW_ID_HERE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Recently Watched",
      "item": [
        {
          "name": "Get History",
          "request": { "method": "GET", "url": "{{baseUrl}}/recently-watched", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Add to History",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/recently-watched",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"contentId\": \"MOVIE_ID_HERE\",\n  \"contentType\": \"movie\",\n  \"progress\": 45\n}" }
          }
        },
        {
          "name": "Clear All History",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/recently-watched", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/stats", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Get All Users",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/users?page=1&limit=20", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Promote User to Admin",
          "request": { "method": "PUT", "url": "{{baseUrl}}/admin/users/USER_ID_HERE/promote", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Delete User",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/users/USER_ID_HERE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    }
  ]
}
